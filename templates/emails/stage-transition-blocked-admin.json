{
  "description": "Sent to admins when a stage transition is blocked because the gate requirements are not met",
  "subject": "[G42 SaaS Factory] {{idea_name}} — Stage Transition Blocked",
  "body": "<div style='font-family: Segoe UI, Arial, sans-serif; max-width: 600px; margin: 0 auto;'><h2 style='color: #1a1a1a; border-bottom: 2px solid #d93f0b; padding-bottom: 8px;'>Stage Transition Blocked</h2><p>A stage transition has been blocked because gate requirements are not met.</p><table style='width: 100%; border-collapse: collapse; margin: 16px 0;'><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; width: 160px; color: #555;'>Idea</td><td style='padding: 8px 12px;'>{{idea_name}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Attempted Transition</td><td style='padding: 8px 12px;'>{{previous_stage}} → {{current_stage}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Reason</td><td style='padding: 8px 12px; color: #d93f0b;'>{{blocked_reason}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Business Unit</td><td style='padding: 8px 12px;'>{{business_unit}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Submitted By</td><td style='padding: 8px 12px;'>{{submitter_name}} ({{submitter_email}})</td></tr></table><p style='margin: 20px 0;'><a href='{{issue_url}}' style='background-color: #d93f0b; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; display: inline-block;'>View Idea on GitHub</a></p><hr style='border: none; border-top: 1px solid #e0e0e0; margin: 20px 0;'><p style='color: #888; font-size: 12px;'>You are receiving this because you are an admin on the G42 SaaS Factory Board.</p></div>"
}
