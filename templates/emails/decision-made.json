{
  "description": "Sent when a decision label (GO Fast-track, GO Modernize, HOLD, or KILL) is applied to an idea",
  "subject": "[G42 SaaS Factory] {{idea_name}} — Decision: {{decision}}",
  "body": "<div style='font-family: Segoe UI, Arial, sans-serif; max-width: 600px; margin: 0 auto;'><h2 style='color: #1a1a1a; border-bottom: 2px solid #0078d4; padding-bottom: 8px;'>Decision Made</h2><p>A decision has been made on the following idea after validation review.</p><table style='width: 100%; border-collapse: collapse; margin: 16px 0;'><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; width: 160px; color: #555;'>Idea</td><td style='padding: 8px 12px;'>{{idea_name}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Business Unit</td><td style='padding: 8px 12px;'>{{business_unit}}</td></tr><tr style='border-bottom: 1px solid #e0e0e0;'><td style='padding: 8px 12px; font-weight: bold; color: #555;'>Decision</td><td style='padding: 8px 12px;'><strong style='font-size: 16px;'>{{decision}}</strong></td></tr></table><p style='margin: 20px 0;'><a href='{{issue_url}}' style='background-color: #0078d4; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; display: inline-block;'>View Details on GitHub</a></p><hr style='border: none; border-top: 1px solid #e0e0e0; margin: 20px 0;'><p style='color: #888; font-size: 12px;'>You are receiving this because you are listed as a stakeholder for this idea on the G42 SaaS Factory Board.</p></div>"
}
